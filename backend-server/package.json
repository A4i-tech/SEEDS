    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "npx eslint src/",
    "lint:fix": "npx eslint src/ --fix && npx prettier src/ --write",
    "fix:file": "npx eslint --fix && npx prettier --write"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@azure/identity": "^4.4.1",
    "@azure/storage-blob": "^12.12.0",
    "agenda": "^5.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "ffmpeg-static": "^5.2.0",
    "firebase-admin": "^13.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "microsoft-cognitiveservices-speech-sdk": "^1.42.0",
    "mongodb-memory-server": "^10.2.3",
    "mongoose": "^9.0.0",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "validator": "^13.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jest": "^30.1.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.3",
    "supertest": "^7.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!coverage/**",
      "!**/*.test.js",
      "!**/*.spec.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "json-summary",
      "json",
      "lcov",
      "text",
      "html"
    ]
  }
