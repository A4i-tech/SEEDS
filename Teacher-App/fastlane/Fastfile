default_platform(:android)

platform :android do

  # Helper method to fix group names (removes spaces, downcases)
  # Example: "Vision Empower, QA Team" -> "vision-empower,qa-team"
  def sanitize_tester_groups(raw_groups)
    return nil if raw_groups.nil? || raw_groups.empty?
    
    sanitized = raw_groups.to_s.split(',').map do |group|
      group.strip.downcase.gsub(' ', '-')
    end.join(',')
    
    return sanitized
  end

  private_lane :load_env_file do |options|
    path = "./#{options[:filename]}"
    UI.message("Attempting to load environment file from: '#{path}'...")

    if File.exist?(path)
      File.foreach(path) do |line|
        next if line.strip.empty? || line.start_with?('#')
        key, value = line.split('=', 2).map(&:strip)
        value = value.gsub(/\A"|"\Z/, '')
        ENV[key] = value
      end
      UI.success("Successfully loaded environment file.")
    else
      if ENV['CI']
        UI.important("File '#{path}' not found. Running in CI mode, assuming environment variables are set directly in the workflow.")
      else
        UI.user_error!("Could not find .env file at path: '#{path}'. Please ensure it exists in the 'fastlane' directory.")
      end
    end
  end

  desc "Build and deploy a STAGING version to Firebase"
  lane :deploy_staging do
    load_env_file(filename: ".env.staging")

    # Sanitize groups dynamically
    staging_groups = sanitize_tester_groups(ENV['FIREBASE_STAGING_TESTER_GROUPS'])
    UI.message("Deploying Staging to groups: #{staging_groups}")

    UI.message("Building Debug APK for staging...")
    gradle(
      task: ":app:assembleDebug",
      properties: {
        "BASE_URL" => ENV['STAGING_BASE_URL'],
        "CONTENT_URL" => ENV['STAGING_CONTENT_URL'],
        "TENANT_NAME" => ENV['STAGING_TENANT_NAME'],

        "STAGING_KEYSTORE_BASE64" => ENV['STAGING_KEYSTORE_BASE64'],
        "STAGING_KEYSTORE_PASSWORD" => ENV['STAGING_KEYSTORE_PASSWORD'],
        "STAGING_KEY_ALIAS" => ENV['STAGING_KEY_ALIAS'],
        "STAGING_KEY_PASSWORD" => ENV['STAGING_KEY_PASSWORD']
      }
    )

    UI.message("Uploading staging build to Firebase App Distribution...")
    firebase_app_distribution(
      app: ENV['FIREBASE_STAGING_APP_ID'],
      apk_path: "app/build/outputs/apk/debug/app-debug.apk",
      groups: staging_groups, 
      firebase_cli_token: ENV['FIREBASE_CLI_TOKEN']
    )

    UI.success("✅ Successfully deployed new STAGING build to Firebase!")
  end

  desc "Build and deploy a PRODUCTION version to Firebase"
  lane :deploy_prod do
    load_env_file(filename: ".env.prod")

    # Sanitize groups dynamically (Fixes "Invalid request" error)
    prod_groups = sanitize_tester_groups(ENV['FIREBASE_PROD_TESTER_GROUPS'])
    UI.message("Deploying Production to groups: #{prod_groups}")

    UI.message("Building Release APK for production...")
    gradle(
      task: ":app:assembleRelease",
      properties: {
        "BASE_URL" => ENV['PROD_BASE_URL'],
        "CONTENT_URL" => ENV['PROD_CONTENT_URL'],
        "TENANT_NAME" => ENV['PROD_TENANT_NAME'],

        "SIGNING_KEYSTORE_BASE64" => ENV['SIGNING_KEYSTORE_BASE64'],
        "SIGNING_KEYSTORE_PASSWORD" => ENV['SIGNING_KEYSTORE_PASSWORD'],
        "SIGNING_KEY_ALIAS" => ENV['SIGNING_KEY_ALIAS'],
        "SIGNING_KEY_PASSWORD" => ENV['SIGNING_KEY_PASSWORD']
      }
    )

    UI.message("Uploading production build to Firebase App Distribution...")
    firebase_app_distribution(
      app: ENV['FIREBASE_PROD_APP_ID'],
      apk_path: "app/build/outputs/apk/release/app-release.apk",
      groups: prod_groups, 
      firebase_cli_token: ENV['FIREBASE_CLI_TOKEN']
    )

    UI.success("✅ Successfully deployed new PRODUCTION build to Firebase!")
  end
end