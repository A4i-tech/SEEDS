<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    
    <data>
        <import type="android.view.View"/>
        <import type="java.text.SimpleDateFormat"/>
        <import type="java.util.Date"/>
        <variable
            name="historyItem"
            type="com.example.seeds.model.ContentHistoryItem" />
        <variable
            name="clickListener"
            type="android.view.View.OnClickListener" />
    </data>

    <androidx.cardview.widget.CardView
        android:id="@+id/history_card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:backgroundTint="@color/white"
        android:tag="@{historyItem}"
        android:onClick="@{clickListener}"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <ImageView
                android:id="@+id/content_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@string/content_icon"
                android:importantForAccessibility="no"
                android:src='@{(historyItem.content.type.equals("Rhyme") || historyItem.content.type.equals("Poem")) ? @drawable/ic_content_music : @drawable/ic_content_book, default=@drawable/ic_content_book}'
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/content_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@{historyItem.content.titleText}"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:importantForAccessibility="yes"
                app:layout_constraintBottom_toTopOf="@+id/content_metadata"
                app:layout_constraintEnd_toStartOf="@+id/play_icon"
                app:layout_constraintStart_toEndOf="@+id/content_icon"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed"
                tools:text="Harry Potter Chapter 1" />

            <TextView
                android:id="@+id/content_metadata"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="12dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#757575"
                android:textSize="15sp"
                android:importantForAccessibility="yes"
                app:layout_constraintBottom_toTopOf="@+id/timestamp_text"
                app:layout_constraintEnd_toStartOf="@+id/play_icon"
                app:layout_constraintStart_toEndOf="@+id/content_icon"
                app:layout_constraintTop_toBottomOf="@+id/content_title"
                tools:text="Story • Kannada" />

            <TextView
                android:id="@+id/timestamp_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="12dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#757575"
                android:textSize="14sp"
                android:importantForAccessibility="yes"
                app:layout_constraintBottom_toTopOf="@+id/session_details_text"
                app:layout_constraintEnd_toStartOf="@+id/play_icon"
                app:layout_constraintStart_toEndOf="@+id/content_icon"
                app:layout_constraintTop_toBottomOf="@+id/content_metadata"
                tools:text="2 hours ago" />

            <TextView
                android:id="@+id/session_details_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="12dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:importantForAccessibility="yes"
                android:visibility="@{historyItem.classroomName != null ? View.VISIBLE : View.GONE}"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/play_icon"
                app:layout_constraintStart_toEndOf="@+id/content_icon"
                app:layout_constraintTop_toBottomOf="@+id/timestamp_text"
                tools:text="📞 Class 5A • 25 students" />

            <ImageView
                android:id="@+id/play_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="@string/play_content"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_play"
                android:tint="?attr/colorPrimary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>
</layout>
