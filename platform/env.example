# ── Platform ──────────────────────────────────────────────────────────────────
APP_MODE=all
ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_DB_CONNECTION_STRING=mongodb://localhost:27017/SEEDS
MONGO_COLLECTION_NAME=conferenceState
MONGO_MAX_POOL_SIZE=50

# ── Cosmos DB (alternative storage backend) ───────────────────────────────────
STORAGE_BACKEND=mongodb
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=
COSMOS_CONTAINER=
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=

# ── Auth / JWT (backend-server) ────────────────────────────────────────────────
PORT=5000
SECRET_KEY=secret-key
AUTH_TYPE=native
JWT_EXPIRES_IN=3000000
PASSWORD_SALT_ROUNDS=2

# ── Vonage ────────────────────────────────────────────────────────────────────
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_APPLICATION_ID=
VONAGE_APPLICATION_PRIVATE_KEY64=
VONAGE_NUMBER=
TO_PHONE_NUMBER=

# ── Azure Service Bus ─────────────────────────────────────────────────────────
SERVICE_BUS_CONNECTION_STRING=
SERVICE_BUS_QUEUE_NAME=
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=

# ── Azure Storage / Blob ──────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ENABLED=
AZURE_STORAGE_ACCOUNT_KEY=
STORAGE_ACCOUNT_NAME=
BLOB_STORE_CONN_STR=

# ── Azure Monitor / Application Insights ──────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── IVR settings ──────────────────────────────────────────────────────────────
BASE_URL=
PROVIDER_TYPE=
CALL_DURATION_LIMIT=
CALL_DURATION_LIMIT_IN_SECONDS=300
STALE_WAIT_IN_MINUTES=60
IVR_DAILY_LISTENING_LIMIT_SECONDS=60
DEFAULT_WELCOME_LANGUAGE=kannada

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_TO_FILE=false
LOG_FILE_PATH=runtime.log

# ── Audio analysis / transcription (ConferenceV2) ─────────────────────────────
AUDIO_ANALYSIS_ENABLED=true
AUDIO_SILENCE_THRESHOLD=300
AUDIO_WEBRTC_VAD_AGGRESSIVENESS=2
AUDIO_VAD_FRAME_MS=20
AUDIO_VAD_START_SPEECH_FRAMES=2
AUDIO_VAD_PRE_SPEECH_MS=120
AUDIO_VAD_MIN_SPEECH_MS=200
AUDIO_VAD_SILENCE_FLUSH_MS=400
AUDIO_VAD_OVERLAP_MS=120
AUDIO_VAD_MAX_SEGMENT_SEC=12
AUDIO_VAD_METRICS_LOG_EVERY_SEGMENTS=20
AUDIO_HOLD_SIMILARITY_THRESHOLD=0.82
AUDIO_HOLD_MIN_TEXT_CHARS=6
AUDIO_ANALYSIS_DB_LOGGING_ENABLED=false

# ── Audio capture / debugging ─────────────────────────────────────────────────
AUDIO_CAPTURE_ENABLED=false
AUDIO_CAPTURE_DIR=/tmp/conference-audio-capture
AUDIO_CAPTURE_MAX_BYTES=104857600
AUDIO_CAPTURE_FLUSH_EVERY_BYTES=32768
AUDIO_CAPTURE_FORMAT=wav
AUDIO_CAPTURE_SAMPLE_RATE_HZ=8000
AUDIO_CAPTURE_CHANNELS=1
AUDIO_CAPTURE_SAMPLE_WIDTH_BYTES=2
AUDIO_CAPTURE_UPLOAD_TO_AZURE=false
AUDIO_CAPTURE_CONTAINER=seedsstagingblob
AUDIO_CAPTURE_BLOB_PREFIX=audio-recording
AUDIO_CAPTURE_DELETE_LOCAL_AFTER_UPLOAD=false
