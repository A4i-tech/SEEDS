    },
    {
      "method": "PATCH",
      "path": "/school/{schoolId}",
      "required_auth": true,
      "expected_status_codes": [200, 400, 401, 404],
      "description": "Update a school"
    },
    {
      "method": "DELETE",
      "path": "/school/{schoolId}",
      "required_auth": true,
      "expected_status_codes": [200, 400, 401, 403, 404],
      "description": "Delete a school"
    },
    {
      "method": "GET",
      "path": "/class",
      "required_auth": true,
      "expected_status_codes": [200, 401],
      "description": "List classes"
    },
    {
      "method": "GET",
      "path": "/class/{classId}",
      "required_auth": true,
      "expected_status_codes": [200, 401, 404],
      "description": "Get class by ID"
    },
    {
      "method": "POST",
      "path": "/class",
      "required_auth": true,
      "expected_status_codes": [200, 400, 401, 403],
      "description": "Create or update a class"
    },
    {
      "method": "DELETE",
      "path": "/class/{classId}",
      "required_auth": true,
      "expected_status_codes": [200, 401, 404],
      "description": "Delete a class"
    },
    {
      "method": "GET",
      "path": "/health",
      "required_auth": false,
      "expected_status_codes": [200],
      "description": "Health check"
    }
  ]
}
