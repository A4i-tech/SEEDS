      "description": "Tenant analytics"
    },
    {
      "method": "POST",
      "path": "/tenant/change-password",
      "required_auth": true,
      "expected_status_codes": [200, 400, 401, 403],
      "description": "Change tenant password"
    },
    {
      "method": "GET",
      "path": "/tenant/dashboard",
      "required_auth": true,
      "expected_status_codes": [200, 401, 403],
      "description": "Tenant dashboard statistics"
    },
