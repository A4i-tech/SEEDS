{
  "name": "websocket-service",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "pretest": "npm run lint:fix",
    "test": "jest test --coverage --no-watch --no-progress",
    "test:watch": "jest --watch",
    "prestart": "npm run lint:fix",
    "start": "node src/server.js",
    "lint": "npx eslint src/",
    "lint:fix": "npx eslint src/ --fix && npx prettier src/ --write"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@azure/storage-blob": "^12.25.0",
    "applicationinsights": "^3.4.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/config/azureConfig.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov",
      "html"
    ],
    "testTimeout": 10000
  }
}
