VONAGE_API_KEY=your_vonage_api_key
VONAGE_API_SECRET=your_vonage_api_secret

# Storage backend: memory | cosmos | mongodb
STORAGE_BACKEND=memory

# MongoDB (required when STORAGE_BACKEND=mongodb)
MONGO_DB_CONNECTION_STRING=mongodb://localhost:27017/SEEDS-Teacher-Backend
MONGO_COLLECTION_NAME=conferenceState
MONGO_MAX_POOL_SIZE=50

# Cosmos DB (required when STORAGE_BACKEND=cosmos)
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=
COSMOS_CONTAINER=

# OpenAI
OPENAI_API_KEY=

# Audio analysis / transcription
AUDIO_SILENCE_THRESHOLD=300
AUDIO_WEBRTC_VAD_AGGRESSIVENESS=2
AUDIO_VAD_FRAME_MS=20
AUDIO_VAD_START_SPEECH_FRAMES=2
AUDIO_VAD_PRE_SPEECH_MS=120
AUDIO_VAD_MIN_SPEECH_MS=200
AUDIO_VAD_SILENCE_FLUSH_MS=400
AUDIO_VAD_OVERLAP_MS=120
AUDIO_VAD_MAX_SEGMENT_SEC=12
AUDIO_VAD_METRICS_LOG_EVERY_SEGMENTS=20
AUDIO_ANALYSIS_DB_LOGGING_ENABLED=false

# Capture raw websocket audio for debugging
AUDIO_CAPTURE_ENABLED=false
AUDIO_CAPTURE_DIR=/tmp/conference-audio-capture
AUDIO_CAPTURE_MAX_BYTES=104857600
AUDIO_CAPTURE_UPLOAD_TO_AZURE=false
AUDIO_CAPTURE_CONTAINER=conference-audio-debug
AUDIO_CAPTURE_DELETE_LOCAL_AFTER_UPLOAD=false

# Azure Blob (required when AUDIO_CAPTURE_UPLOAD_TO_AZURE=true)
AZURE_STORAGE_CONNECTION_STRING=
